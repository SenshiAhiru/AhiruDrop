{
  "name": "ahirudrop-videos",
  "version": "0.1.0",
  "description": "AhiruDrop motion templates rendered via Remotion (React → MP4).",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render",

    "render:logo": "remotion render LogoIntro out/logo-intro.mp4",
    "render:logo-square": "remotion render LogoIntroSquare out/logo-intro-square.mp4",
    "render:logo-horizontal": "remotion render LogoIntroHorizontal out/logo-intro-horizontal.mp4",

    "// === Pro formats for editing in Premiere / After Effects === ": "",
    "render:logo-prores": "remotion render LogoIntro out/logo-intro.mov --codec=prores --prores-profile=hq",
    "render:logo-alpha": "remotion render LogoIntroTransparent out/logo-intro-alpha.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",

    "// === Site showcase (15s) === ": "",
    "render:showcase": "remotion render SiteShowcase out/site-showcase.mp4",
    "render:showcase-square": "remotion render SiteShowcaseSquare out/site-showcase-square.mp4",
    "render:showcase-horizontal": "remotion render SiteShowcaseHorizontal out/site-showcase-horizontal.mp4",
    "render:showcase-prores": "remotion render SiteShowcaseHorizontal out/site-showcase.mov --codec=prores --prores-profile=hq",

    "// === Individual scenes as transparent ProRes 4444 (Premiere layers) === ": "",
    "render:scene-01": "remotion render Scene01Hook out/scene-01-hook-alpha.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",
    "render:scene-02": "remotion render Scene02Browse out/scene-02-browse-alpha.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",
    "render:scene-03": "remotion render Scene03Buy out/scene-03-buy-alpha.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",
    "render:scene-04": "remotion render Scene04Draw out/scene-04-draw-alpha.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",
    "render:scene-05": "remotion render Scene05Win out/scene-05-win-alpha.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",
    "render:scenes-all": "npm run render:scene-01 && npm run render:scene-02 && npm run render:scene-03 && npm run render:scene-04 && npm run render:scene-05",

    "render:all": "npm run render:logo && npm run render:logo-square && npm run render:logo-horizontal"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
