generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  DRAWN
  CANCELLED
}

enum NumberStatus {
  AVAILABLE
  RESERVED
  PAID
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  REFUNDED
  CANCELLED
}

enum NotificationType {
  ORDER_CONFIRMED
  PAYMENT_RECEIVED
  RAFFLE_DRAWN
  WINNER_NOTIFICATION
  TICKET_EXPIRED
  SYSTEM
  // Support
  SUPPORT_NEW_TICKET
  SUPPORT_NEW_MESSAGE
  // Admin-only operational
  RAFFLE_READY_TO_DRAW
  BIG_DEPOSIT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  emailVerified  DateTime?
  phone          String?        @unique
  cpf            String?        @unique
  steamId        String?        @unique
  steamTradeUrl  String?
  passwordHash   String
  role           Role           @default(USER)
  avatarUrl      String?
  balance        Decimal        @default(0) @db.Decimal(10, 2)
  isActive       Boolean        @default(true)
  onboardedAt    DateTime?      // null = user hasn't completed the welcome tutorial
  signupIp       String?        // first IP used at signup (best-effort)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  orders         Order[]
  notifications  Notification[]
  auditLogs       AuditLog[]       @relation("AuditActor")
  supportTickets  SupportTicket[]
  supportMessages SupportMessage[] @relation("SupportSender")
  raffleDraws     RaffleDraw[]     @relation("DrawAdmin")
  tradeRequests   TradeRequest[]

  @@index([signupIp])
  @@map("users")
}

model Raffle {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  description      String       @db.Text
  shortDescription String?
  pricePerNumber   Decimal      @db.Decimal(10, 2)
  totalNumbers     Int
  minPerPurchase   Int          @default(1)
  maxPerPurchase   Int          @default(10)
  status           RaffleStatus @default(DRAFT)
  featuredImage    String?
  category         String?
  prizeType        String?
  regulation       String?      @db.Text
  // CS2 Skin fields
  skinName         String?
  skinImage        String?
  skinWeapon       String?
  skinCategory     String?
  skinRarity       String?
  skinRarityColor  String?
  skinWear         String?
  skinFloat        Decimal?     @db.Decimal(16, 13)
  skinStatTrak     Boolean      @default(false)
  skinSouvenir     Boolean      @default(false)
  skinExteriorMin  Decimal?     @db.Decimal(4, 2)
  skinExteriorMax  Decimal?     @db.Decimal(4, 2)
  skinMarketPrice  Decimal?     @db.Decimal(10, 2)
  scheduledDrawAt  DateTime?
  closedAt         DateTime?
  isFeatured       Boolean      @default(false)
  // Provably fair — committed at raffle creation
  serverSeedHash      String?   // SHA-256(serverSeed), public immediately
  serverSeedEncrypted String?   // AES-256-GCM(serverSeed), revealed at draw
  drawBlockHeight     Int?      // Bitcoin block height used as public beacon
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  images     RaffleImage[]
  numbers    RaffleNumber[]
  orderItems OrderItem[]
  draws      RaffleDraw[]

  @@index([status])
  @@index([slug])
  @@map("raffles")
}

model RaffleImage {
  id        String   @id @default(cuid())
  raffleId  String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@map("raffle_images")
}

model RaffleNumber {
  id            String       @id @default(cuid())
  raffleId      String
  number        Int
  status        NumberStatus @default(AVAILABLE)
  reservedUntil DateTime?
  orderId       String?

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@unique([raffleId, number])
  @@index([raffleId, status])
  @@index([reservedUntil])
  @@map("raffle_numbers")
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  finalAmount Decimal     @db.Decimal(10, 2)
  expiresAt   DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  items    OrderItem[]
  numbers  RaffleNumber[]
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  raffleId       String
  quantity       Int
  pricePerNumber Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  gatewayId       String
  externalId      String?
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  method          String?
  gatewayResponse Json?
  paidAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order   Order          @relation(fields: [orderId], references: [id])
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id])
  logs    PaymentLog[]

  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@map("payments")
}

model PaymentLog {
  id        String   @id @default(cuid())
  paymentId String
  event     String
  data      Json
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_logs")
}

model PaymentGateway {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  isActive    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  sandbox     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  configs  PaymentGatewayConfig[]
  payments Payment[]

  @@map("payment_gateways")
}

model PaymentGatewayConfig {
  id        String   @id @default(cuid())
  gatewayId String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gateway PaymentGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@unique([gatewayId, key])
  @@map("payment_gateway_configs")
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountType    String
  discountValue   Decimal   @db.Decimal(10, 2)
  maxUses         Int?      // total across all users; null = unlimited
  maxUsesPerUser  Int?      // per-user limit; null = no per-user cap
  currentUses     Int       @default(0)
  minOrderAmount  Decimal?  @db.Decimal(10, 2)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptions CouponRedemption[]

  @@map("coupons")
}

model Deposit {
  id                String    @id @default(cuid())
  userId            String
  paymentIntentId   String    @unique
  currency          String    // "BRL" | "USD" | "EUR" | "GBP"
  amountPaid        Decimal   @db.Decimal(10, 2) // original currency charged by Stripe
  ahcBase           Decimal   @db.Decimal(10, 2) // AHC credited before bonus
  ahcBonus          Decimal   @default(0) @db.Decimal(10, 2)
  ahcTotal          Decimal   @db.Decimal(10, 2) // base + bonus
  couponId          String?
  couponCode        String?
  status            String    @default("PENDING") // "PENDING" | "COMPLETED" | "FAILED"
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([paymentIntentId])
  @@map("deposits")
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  userId      String
  context     String   // "deposit" | "order"
  referenceId String?  // Stripe payment intent id or Order id
  bonusAhc    Decimal  @default(0) @db.Decimal(10, 2) // AHC bonus granted at redemption time
  createdAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model RaffleDraw {
  id            String   @id @default(cuid())
  raffleId      String
  adminId       String
  winningNumber Int
  resultHash    String
  seed          String
  drawMethod    String   @default("crypto")
  // Provably fair — revealed at draw time
  serverSeedRevealed String?  // Plain serverSeed, revealed after draw
  blockHash          String?  // Bitcoin block hash used as beacon
  blockHeight        Int?     // Bitcoin block height
  drawnAt       DateTime @default(now())

  raffle Raffle  @relation(fields: [raffleId], references: [id], onDelete: Restrict)
  admin  User    @relation("DrawAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  winner Winner?

  @@map("raffle_draws")
}

model Winner {
  id        String    @id @default(cuid())
  drawId    String    @unique
  raffleId  String
  userId    String
  numberWon Int
  claimedAt DateTime?
  seenAt    DateTime?  // null = popup not shown yet
  createdAt DateTime  @default(now())

  draw         RaffleDraw    @relation(fields: [drawId], references: [id], onDelete: Restrict)
  tradeRequest TradeRequest?

  @@index([userId])
  @@map("winners")
}

model TradeRequest {
  id                String       @id @default(cuid())
  winnerId          String       @unique
  userId            String
  steamTradeUrl     String
  steamTradeOfferId String?      // Steam trade offer ID for verification
  status            TradeStatus  @default(PENDING)
  adminNotes        String?      @db.Text
  sentAt            DateTime?
  completedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  winner Winner @relation(fields: [winnerId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@map("trade_requests")
}

enum TradeStatus {
  PENDING       // user solicitou, admin ainda não agiu
  SENT          // admin enviou a trade offer via Steam
  COMPLETED     // trade aceito, skin entregue
  FAILED        // trade falhou ou expirou
  CANCELLED     // user ou admin cancelou
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String       @db.Text         // first message (kept for compat with older tickets)
  category  String       @default("outro") // "duvida" | "pagamento" | "rifa" | "tecnico" | "outro"
  status    TicketStatus @default(OPEN)
  priority  Int          @default(0)
  closedAt  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User             @relation(fields: [userId], references: [id])
  messages SupportMessage[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String?  // user who wrote it; null if system-generated
  senderRole  String   // "USER" | "ADMIN" | "SYSTEM"
  body        String   @db.Text
  readByUser  Boolean  @default(false)
  readByAdmin Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?         @relation("SupportSender", fields: [senderId], references: [id])

  @@index([ticketId])
  @@index([senderId])
  @@map("support_messages")
}

model SteamLoginToken {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("steam_login_tokens")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
