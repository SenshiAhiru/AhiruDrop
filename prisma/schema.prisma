generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  DRAWN
  CANCELLED
}

enum NumberStatus {
  AVAILABLE
  RESERVED
  PAID
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  REFUNDED
  CANCELLED
}

enum NotificationType {
  ORDER_CONFIRMED
  PAYMENT_RECEIVED
  RAFFLE_DRAWN
  WINNER_NOTIFICATION
  TICKET_EXPIRED
  SYSTEM
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  emailVerified  DateTime?
  phone          String?        @unique
  cpf            String?        @unique
  steamId        String?        @unique
  passwordHash   String
  role           Role           @default(USER)
  avatarUrl      String?
  balance        Decimal        @default(0) @db.Decimal(10, 2)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  orders         Order[]
  notifications  Notification[]
  auditLogs      AuditLog[]     @relation("AuditActor")
  supportTickets SupportTicket[]
  raffleDraws    RaffleDraw[]   @relation("DrawAdmin")

  @@map("users")
}

model Raffle {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  description      String       @db.Text
  shortDescription String?
  pricePerNumber   Decimal      @db.Decimal(10, 2)
  totalNumbers     Int
  minPerPurchase   Int          @default(1)
  maxPerPurchase   Int          @default(10)
  status           RaffleStatus @default(DRAFT)
  featuredImage    String?
  category         String?
  prizeType        String?
  regulation       String?      @db.Text
  // CS2 Skin fields
  skinName         String?
  skinImage        String?
  skinWeapon       String?
  skinCategory     String?
  skinRarity       String?
  skinRarityColor  String?
  skinWear         String?
  skinFloat        Decimal?     @db.Decimal(16, 13)
  skinStatTrak     Boolean      @default(false)
  skinSouvenir     Boolean      @default(false)
  skinExteriorMin  Decimal?     @db.Decimal(4, 2)
  skinExteriorMax  Decimal?     @db.Decimal(4, 2)
  skinMarketPrice  Decimal?     @db.Decimal(10, 2)
  scheduledDrawAt  DateTime?
  closedAt         DateTime?
  isFeatured       Boolean      @default(false)
  // Provably fair — committed at raffle creation
  serverSeedHash      String?   // SHA-256(serverSeed), public immediately
  serverSeedEncrypted String?   // AES-256-GCM(serverSeed), revealed at draw
  drawBlockHeight     Int?      // Bitcoin block height used as public beacon
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  images     RaffleImage[]
  numbers    RaffleNumber[]
  orderItems OrderItem[]
  draws      RaffleDraw[]

  @@index([status])
  @@index([slug])
  @@map("raffles")
}

model RaffleImage {
  id        String   @id @default(cuid())
  raffleId  String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@map("raffle_images")
}

model RaffleNumber {
  id            String       @id @default(cuid())
  raffleId      String
  number        Int
  status        NumberStatus @default(AVAILABLE)
  reservedUntil DateTime?
  orderId       String?

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@unique([raffleId, number])
  @@index([raffleId, status])
  @@index([reservedUntil])
  @@map("raffle_numbers")
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  finalAmount Decimal     @db.Decimal(10, 2)
  couponId    String?
  expiresAt   DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  coupon   Coupon?        @relation(fields: [couponId], references: [id])
  items    OrderItem[]
  numbers  RaffleNumber[]
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  raffleId       String
  quantity       Int
  pricePerNumber Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raffle Raffle @relation(fields: [raffleId], references: [id])

  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  gatewayId       String
  externalId      String?
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  method          String?
  gatewayResponse Json?
  paidAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order   Order          @relation(fields: [orderId], references: [id])
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id])
  logs    PaymentLog[]

  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@map("payments")
}

model PaymentLog {
  id        String   @id @default(cuid())
  paymentId String
  event     String
  data      Json
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_logs")
}

model PaymentGateway {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  isActive    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  sandbox     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  configs  PaymentGatewayConfig[]
  payments Payment[]

  @@map("payment_gateways")
}

model PaymentGatewayConfig {
  id        String   @id @default(cuid())
  gatewayId String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gateway PaymentGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@unique([gatewayId, key])
  @@map("payment_gateway_configs")
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String
  discountValue  Decimal   @db.Decimal(10, 2)
  maxUses        Int?
  currentUses    Int       @default(0)
  minOrderAmount Decimal?  @db.Decimal(10, 2)
  validFrom      DateTime  @default(now())
  validUntil     DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders Order[]

  @@map("coupons")
}

model RaffleDraw {
  id            String   @id @default(cuid())
  raffleId      String
  adminId       String
  winningNumber Int
  resultHash    String
  seed          String
  drawMethod    String   @default("crypto")
  // Provably fair — revealed at draw time
  serverSeedRevealed String?  // Plain serverSeed, revealed after draw
  blockHash          String?  // Bitcoin block hash used as beacon
  blockHeight        Int?     // Bitcoin block height
  drawnAt       DateTime @default(now())

  raffle Raffle  @relation(fields: [raffleId], references: [id])
  admin  User    @relation("DrawAdmin", fields: [adminId], references: [id])
  winner Winner?

  @@map("raffle_draws")
}

model Winner {
  id        String    @id @default(cuid())
  drawId    String    @unique
  raffleId  String
  userId    String
  numberWon Int
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  draw RaffleDraw @relation(fields: [drawId], references: [id])

  @@index([userId])
  @@map("winners")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String       @db.Text
  status    TicketStatus @default(OPEN)
  priority  Int          @default(0)
  closedAt  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
