{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "AhiruDrop",
  "version": "1.0.0",
  "description": "Official AhiruDrop color palette. Source of truth: src/app/globals.css.",
  "colors": {
    "primary": {
      "description": "Brand primary — purple. Used for CTAs, links, focus rings.",
      "50": { "value": "#f5f3ff", "type": "color" },
      "100": { "value": "#ede9fe", "type": "color" },
      "200": { "value": "#ddd6fe", "type": "color" },
      "300": { "value": "#c4b5fd", "type": "color" },
      "400": { "value": "#a78bfa", "type": "color" },
      "500": { "value": "#8b5cf6", "type": "color" },
      "600": { "value": "#7c3aed", "type": "color", "primary": true },
      "700": { "value": "#6d28d9", "type": "color" },
      "800": { "value": "#5b21b6", "type": "color" },
      "900": { "value": "#4c1d95", "type": "color" },
      "950": { "value": "#2e1065", "type": "color" }
    },
    "accent": {
      "description": "Brand accent — gold/amber. Used for AHC values, trophies, secondary CTAs.",
      "50": { "value": "#fffbeb", "type": "color" },
      "100": { "value": "#fef3c7", "type": "color" },
      "200": { "value": "#fde68a", "type": "color" },
      "300": { "value": "#fcd34d", "type": "color" },
      "400": { "value": "#fbbf24", "type": "color", "primary": true },
      "500": { "value": "#f59e0b", "type": "color", "primary": true },
      "600": { "value": "#d97706", "type": "color" },
      "700": { "value": "#b45309", "type": "color" },
      "800": { "value": "#92400e", "type": "color" },
      "900": { "value": "#78350f", "type": "color" }
    },
    "semantic": {
      "description": "Status colors — apply only to corresponding states, never decoratively.",
      "success": { "value": "#10b981", "type": "color" },
      "warning": { "value": "#f59e0b", "type": "color" },
      "danger": { "value": "#ef4444", "type": "color" },
      "info": { "value": "#3b82f6", "type": "color" }
    },
    "surface": {
      "description": "Theme-aware neutral scale. Inverts between light and dark mode in CSS — JSON shows the dark-mode default.",
      "dark": {
        "50": { "value": "#fafafa", "type": "color", "role": "text-primary" },
        "100": { "value": "#f4f4f5", "type": "color" },
        "200": { "value": "#e4e4e7", "type": "color" },
        "300": { "value": "#d4d4d8", "type": "color" },
        "400": { "value": "#a1a1aa", "type": "color", "role": "text-muted" },
        "500": { "value": "#71717a", "type": "color", "role": "placeholder" },
        "600": { "value": "#52525b", "type": "color" },
        "700": { "value": "#3f3f46", "type": "color", "role": "border" },
        "800": { "value": "#27272a", "type": "color", "role": "card-alt" },
        "900": { "value": "#18181b", "type": "color", "role": "card" },
        "950": { "value": "#09090b", "type": "color", "role": "background" }
      },
      "light": {
        "50": { "value": "#09090b", "type": "color", "role": "text-primary" },
        "100": { "value": "#18181b", "type": "color" },
        "200": { "value": "#27272a", "type": "color" },
        "300": { "value": "#3f3f46", "type": "color" },
        "400": { "value": "#52525b", "type": "color", "role": "text-muted" },
        "500": { "value": "#71717a", "type": "color", "role": "placeholder" },
        "600": { "value": "#a1a1aa", "type": "color" },
        "700": { "value": "#d4d4d8", "type": "color", "role": "border" },
        "800": { "value": "#e4e4e7", "type": "color", "role": "card-alt" },
        "900": { "value": "#f4f4f5", "type": "color", "role": "card" },
        "950": { "value": "#fafafa", "type": "color", "role": "background" }
      }
    },
    "rarity": {
      "description": "CS2 official rarity colors (Valve standard). Applied in card borders and tags.",
      "consumerGrade":   { "value": "#b0c3d9", "type": "color", "label": "Consumer Grade" },
      "industrialGrade": { "value": "#5e98d9", "type": "color", "label": "Industrial Grade" },
      "milSpec":         { "value": "#4b69ff", "type": "color", "label": "Mil-Spec Grade" },
      "restricted":      { "value": "#8847ff", "type": "color", "label": "Restricted" },
      "classified":      { "value": "#d32ce6", "type": "color", "label": "Classified" },
      "covert":          { "value": "#eb4b4b", "type": "color", "label": "Covert" },
      "contraband":      { "value": "#e4ae39", "type": "color", "label": "Contraband / Extraordinary" }
    },
    "wear": {
      "description": "CS2 wear conditions, ordered by float range.",
      "factoryNew":     { "value": "#4ade80", "type": "color", "label": "Factory New",     "floatMax": 0.07 },
      "minimalWear":    { "value": "#a3e635", "type": "color", "label": "Minimal Wear",    "floatMax": 0.15 },
      "fieldTested":    { "value": "#facc15", "type": "color", "label": "Field-Tested",    "floatMax": 0.38 },
      "wellWorn":       { "value": "#fb923c", "type": "color", "label": "Well-Worn",       "floatMax": 0.45 },
      "battleScarred":  { "value": "#ef4444", "type": "color", "label": "Battle-Scarred",  "floatMax": 1.00 }
    },
    "external": {
      "description": "Third-party brand colors used in integrations.",
      "discord": { "value": "#5865F2", "type": "color" },
      "steam":   { "value": "#171a21", "type": "color" }
    }
  },
  "typography": {
    "sans": { "value": "Geist Sans", "type": "fontFamily" },
    "mono": { "value": "Geist Mono", "type": "fontFamily" }
  },
  "radius": {
    "sm":   { "value": "0.375rem", "type": "borderRadius", "px": "6px" },
    "md":   { "value": "0.5rem",   "type": "borderRadius", "px": "8px" },
    "lg":   { "value": "0.75rem",  "type": "borderRadius", "px": "12px" },
    "xl":   { "value": "1rem",     "type": "borderRadius", "px": "16px" },
    "2xl":  { "value": "1.5rem",   "type": "borderRadius", "px": "24px" }
  },
  "gradients": {
    "brand": {
      "value": "linear-gradient(135deg, #7c3aed 0%, #f59e0b 100%)",
      "type": "gradient",
      "description": "Primary brand gradient — purple to gold."
    }
  }
}
